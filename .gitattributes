# Normalize line endings for all files
* text=auto

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Go
*.go text eol=lf

# Python
*.py text eol=lf
*.pyx text eol=lf
*.pyi text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# Markdown
*.md text eol=lf

# JSON
*.json text eol=lf

# Lock files
poetry.lock text eol=lf
go.sum text eol=lf

# Windows files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
