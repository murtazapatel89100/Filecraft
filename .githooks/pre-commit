#!/usr/bin/env bash
# pre-commit hook: lint both Python and Go code.
set -euo pipefail

echo "==> [pre-commit] Running Python lint (black)..."
cd filecraft-python
if command -v poetry &>/dev/null; then
    poetry run python -m black --check src tests
else
    echo "ERROR: Poetry not found. Python linting cannot run."
    echo "Please format the Python code manually using:"
    echo "  black src tests"
    echo "Then commit again."
    exit 1
fi
cd ..

echo "==> [pre-commit] Running Go lint (gofmt + go vet)..."
cd filecraft-go
UNFORMATTED=$(gofmt -l .)
if [ -n "$UNFORMATTED" ]; then
    echo "ERROR: The following Go files are not formatted:"
    echo "$UNFORMATTED"
    echo "Run 'gofmt -w .' to fix them before committing."
    exit 1
fi

go vet ./...
cd ..

echo "==> [pre-commit] All lint checks passed."